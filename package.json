{
  "name": "awesome-ai-radar",
  "version": "1.0.0",
  "description": "Community-powered AI trend radar — track what matters, ignore the noise",
  "main": ".eleventy.js",
  "scripts": {
    "build": "eleventy",
    "serve": "eleventy --serve",
    "search-index": "pagefind --site _site",
    "build:full": "npm run build && npm run search-index"
  },
  "keywords": [
    "ai",
    "radar",
    "trends",
    "community",
    "awesome-list",
    "eleventy"
  ],
  "author": "Orkhan Rzazade <o.rzazade@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@11ty/eleventy": "^3.0.0"
  },
  "devDependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "pagefind": "^1.3.0",
    "@pagefind/default-ui": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
