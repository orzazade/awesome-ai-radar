{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orzazade.github.io/awesome-ai-radar/schema/entry.schema.json",
  "title": "AI Radar Entry",
  "description": "Schema for an AI Radar pulse entry",
  "type": "object",
  "required": [
    "title",
    "date",
    "category",
    "signal",
    "affects",
    "source",
    "what_happened",
    "why_it_matters",
    "who_should_pay_attention",
    "contributed_by"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short, descriptive title of the AI event or release"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of the event in YYYY-MM-DD format"
    },
    "category": {
      "type": "string",
      "enum": [
        "Model Release",
        "Tool",
        "Framework",
        "Paradigm",
        "Infrastructure",
        "Research"
      ],
      "description": "Primary category of the entry"
    },
    "signal": {
      "type": "string",
      "enum": [
        "game-changer",
        "notable",
        "incremental",
        "noise"
      ],
      "description": "Signal strength rating"
    },
    "affects": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Stack tags affected by this entry (e.g., 'backend', 'frontend', 'devops', 'mobile')"
    },
    "source": {
      "type": "string",
      "format": "uri",
      "description": "Primary source URL for the announcement or release"
    },
    "what_happened": {
      "type": "string",
      "minLength": 10,
      "description": "Factual summary of the event"
    },
    "why_it_matters": {
      "type": "string",
      "minLength": 10,
      "description": "Analysis of significance and potential impact"
    },
    "who_should_pay_attention": {
      "type": "string",
      "minLength": 5,
      "description": "Target audience or roles most affected"
    },
    "contributed_by": {
      "type": "string",
      "minLength": 1,
      "description": "GitHub username of the contributor"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "Optional additional tags for discoverability"
    },
    "radar_quadrant": {
      "type": "string",
      "enum": [
        "Models",
        "Tools",
        "Frameworks",
        "Paradigms"
      ],
      "description": "Radar quadrant placement"
    },
    "radar_ring": {
      "type": "string",
      "enum": [
        "Adopt",
        "Trial",
        "Assess",
        "Hold"
      ],
      "description": "Radar ring placement"
    }
  },
  "additionalProperties": false
}
