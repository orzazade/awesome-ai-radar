---
layout: layouts/base.njk
title: ""
---

<section class="hero">
  <h1 class="hero-title">awesome-ai-radar</h1>
  <p class="hero-tagline">Track what matters. Ignore the noise.</p>
</section>

<section class="radar-section">
  <div id="radar-chart" aria-label="AI Radar Visualization"></div>
</section>

<section class="stats-bar">
  <h2>This Week in Numbers</h2>
  <div class="stats-grid">
    <div class="stat-card stat-game-changer">
      <span class="stat-number">{{ collections.pulse | countBySignal("game-changer") }}</span>
      <span class="stat-label">Game Changers</span>
    </div>
    <div class="stat-card stat-notable">
      <span class="stat-number">{{ collections.pulse | countBySignal("notable") }}</span>
      <span class="stat-label">Notable</span>
    </div>
    <div class="stat-card stat-incremental">
      <span class="stat-number">{{ collections.pulse | countBySignal("incremental") }}</span>
      <span class="stat-label">Incremental</span>
    </div>
    <div class="stat-card stat-noise">
      <span class="stat-number">{{ collections.pulse | countBySignal("noise") }}</span>
      <span class="stat-label">Noise</span>
    </div>
  </div>
</section>

{# What's Hot — top 5 by relevance score #}
{% if collections.hot.length %}
<section class="whats-hot">
  <h2>What's Hot Right Now</h2>
  <div class="hot-grid">
    {% for entry in collections.hot %}
      <a href="{{ entry.url }}" class="hot-card">
        <span class="hot-signal signal-badge signal-{{ entry.data.signal }}">{{ entry.data.signal }}</span>
        <span class="hot-title">{{ entry.data.title }}</span>
        <span class="hot-meta">{{ entry.data.category }} · {{ entry.date | dateReadable }}</span>
      </a>
    {% endfor %}
  </div>
</section>
{% endif %}

<section class="digest">
  <h2>All Entries</h2>
  <p class="digest-subtitle">Sorted by relevance — most important first</p>

  {# Relevance-sorted listing (no longer grouped by signal) #}
  {% for entry in collections.pulse %}
    {% include "partials/entry-card.njk" %}
  {% endfor %}

  {% if not collections.pulse.length %}
    <p class="empty-state">No entries yet. Run <code>/ai-radar contribute</code> to add the first one!</p>
  {% endif %}
</section>

<script src="/awesome-ai-radar/js/radar.js" defer></script>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero-title {
    font-size: 2.5rem;
    letter-spacing: -0.04em;
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  .radar-section {
    margin: 2rem 0;
  }

  #radar-chart {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    aspect-ratio: 1;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .stats-bar {
    margin: 2rem 0;
  }

  .stats-bar h2 {
    margin-bottom: 1rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .stat-card {
    text-align: center;
    padding: 1.25rem 0.75rem;
    border-radius: var(--radius);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 0.25rem;
  }

  .stat-game-changer .stat-number { color: var(--signal-game-changer); }
  .stat-notable .stat-number { color: var(--signal-notable); }
  .stat-incremental .stat-number { color: var(--signal-incremental); }
  .stat-noise .stat-number { color: var(--signal-noise); }

  .digest {
    margin: 2rem 0;
  }

  .digest h2 {
    margin-bottom: 1.5rem;
  }

  .digest h3 {
    margin: 1.5rem 0 1rem;
  }

  .whats-hot {
    margin: 2rem 0;
  }

  .whats-hot h2 {
    margin-bottom: 1rem;
  }

  .hot-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hot-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s;
  }

  .hot-card:hover {
    border-color: var(--signal-notable);
  }

  .hot-signal {
    flex-shrink: 0;
    font-size: 0.7rem;
  }

  .hot-title {
    flex: 1;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .hot-meta {
    flex-shrink: 0;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .digest-subtitle {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: -1rem;
    margin-bottom: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 1rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
  }

  @media (max-width: 640px) {
    .hero-title { font-size: 1.75rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .hot-card { flex-wrap: wrap; }
    .hot-meta { width: 100%; margin-left: calc(0.75rem + 4rem); }
  }
</style>
