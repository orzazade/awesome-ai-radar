---
layout: layouts/base.njk
title: ""
---

<section class="hero">
  <h1 class="hero-title">awesome-ai-radar</h1>
  <p class="hero-tagline">Track what matters. Ignore the noise.</p>
</section>

<section class="radar-section">
  <div id="radar-chart" aria-label="AI Radar Visualization"></div>
</section>

<section class="stats-bar">
  <h2>This Week in Numbers</h2>
  <div class="stats-grid">
    <div class="stat-card stat-game-changer">
      <span class="stat-number">{{ collections.pulse | countBySignal("game-changer") }}</span>
      <span class="stat-label">Game Changers</span>
    </div>
    <div class="stat-card stat-notable">
      <span class="stat-number">{{ collections.pulse | countBySignal("notable") }}</span>
      <span class="stat-label">Notable</span>
    </div>
    <div class="stat-card stat-incremental">
      <span class="stat-number">{{ collections.pulse | countBySignal("incremental") }}</span>
      <span class="stat-label">Incremental</span>
    </div>
    <div class="stat-card stat-noise">
      <span class="stat-number">{{ collections.pulse | countBySignal("noise") }}</span>
      <span class="stat-label">Noise</span>
    </div>
  </div>
</section>

<section class="digest">
  <h2>Latest Entries</h2>

  {# Game Changers first #}
  {% set gcEntries = collections.pulse | filterBySignal("game-changer") %}
  {% if gcEntries.length %}
    <h3><span class="signal-badge signal-game-changer">Game Changer</span></h3>
    {% for entry in gcEntries %}
      {% include "partials/entry-card.njk" %}
    {% endfor %}
  {% endif %}

  {# Notable #}
  {% set notableEntries = collections.pulse | filterBySignal("notable") %}
  {% if notableEntries.length %}
    <h3><span class="signal-badge signal-notable">Notable</span></h3>
    {% for entry in notableEntries %}
      {% include "partials/entry-card.njk" %}
    {% endfor %}
  {% endif %}

  {# Incremental #}
  {% set incEntries = collections.pulse | filterBySignal("incremental") %}
  {% if incEntries.length %}
    <h3><span class="signal-badge signal-incremental">Incremental</span></h3>
    {% for entry in incEntries %}
      {% include "partials/entry-card.njk" %}
    {% endfor %}
  {% endif %}

  {# Noise #}
  {% set noiseEntries = collections.pulse | filterBySignal("noise") %}
  {% if noiseEntries.length %}
    <h3><span class="signal-badge signal-noise">Noise</span></h3>
    {% for entry in noiseEntries %}
      {% include "partials/entry-card.njk" %}
    {% endfor %}
  {% endif %}

  {% if not collections.pulse.length %}
    <p class="empty-state">No entries yet. Run <code>/ai-radar contribute</code> to add the first one!</p>
  {% endif %}
</section>

<script src="/js/radar.js" defer></script>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero-title {
    font-size: 2.5rem;
    letter-spacing: -0.04em;
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  .radar-section {
    margin: 2rem 0;
  }

  #radar-chart {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    aspect-ratio: 1;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .stats-bar {
    margin: 2rem 0;
  }

  .stats-bar h2 {
    margin-bottom: 1rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .stat-card {
    text-align: center;
    padding: 1.25rem 0.75rem;
    border-radius: var(--radius);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 0.25rem;
  }

  .stat-game-changer .stat-number { color: var(--signal-game-changer); }
  .stat-notable .stat-number { color: var(--signal-notable); }
  .stat-incremental .stat-number { color: var(--signal-incremental); }
  .stat-noise .stat-number { color: var(--signal-noise); }

  .digest {
    margin: 2rem 0;
  }

  .digest h2 {
    margin-bottom: 1.5rem;
  }

  .digest h3 {
    margin: 1.5rem 0 1rem;
  }

  .empty-state {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 1rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
  }

  @media (max-width: 640px) {
    .hero-title { font-size: 1.75rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
